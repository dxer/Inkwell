# === 管理后台认证 ===
# 优先使用加盐哈希（推荐）：用 tools/gen-admin-hash.mjs 生成后填入
#   node tools/gen-admin-hash.mjs "your_password"
# 然后： wrangler secret put ADMIN_PASSWORD_HASH
# 明文 ADMIN_PASSWORD 仍兼容，但会打印不安全警告，请勿用于生产。
ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=pbkdf2$sha256$200000$<salt>$<hash>
# ADMIN_PASSWORD=admin_secure_password

# === Session Cookie 加密密钥 ===
# 请改为一个足够长的随机字符串（至少 32 字符）
SESSION_SECRET=change_this_to_a_random_string_at_least_32_chars_long

# Optional: Cloudflare credentials for testing Workers AI locally in development
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === AI 模型 API Key 加密密钥（AES-256-GCM）===
# 32 字节 base64，例如：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_ENC_KEY=
