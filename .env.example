# === 管理后台认证 ===
# ⚠️ 开源仓库中不要填写真实密码。首次使用请修改后复制为 .env
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_secure_password

# === Session Cookie 加密密钥 ===
# 请改为一个足够长的随机字符串（至少 32 字符）
SESSION_SECRET=change_this_to_a_random_string_at_least_32_chars_long

# Optional: Cloudflare credentials for testing Workers AI locally in development
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
